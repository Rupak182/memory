{
  "name": "memory",
  "version": "1.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun --cwd packages/server dev --persist-to=../../local-db",
    "typegen": "bun --cwd packages/server cf-typegen",
    "db:generate": "bun --cwd packages/database db:generate",
    "db:push": "bun --cwd packages/database db:push",
    "db:migrate:local": "bun --cwd packages/server wrangler d1 migrations apply memory-db --local --persist-to=../../local-db",
    "db:migrate:remote": "bun --cwd packages/server wrangler d1 migrations apply memory-db --remote",
    "lint": "eslint .",
    "test": "bun --cwd packages/database test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.62.1"
  }
}